# Example local environment settings for the Financial News Intelligence project.
# Copy this file to `.env` only if you want local overrides.
# Do not put real secrets into `.env.example`.

PROJECT_ENV=local
PROJECT_TIMEZONE=Asia/Shanghai
PYTHONUTF8=1

# Optional: Streamlit settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Optional: crawler politeness settings
NEWS_REQUEST_DELAY_SECONDS=1.5
NEWS_MAX_PAGES=20

# Optional: if an external LLM service is added later, place keys only in `.env`.
# OPENAI_API_KEY=
# COZE_API_KEY=
